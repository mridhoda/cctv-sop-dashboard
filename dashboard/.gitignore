# ============================================
# DASHBOARD - .gitignore
# React + Vite Project
# ============================================

# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Runtime Data ---
pids
*.pid
*.seed
*.pid.lock

# --- Dependencies ---
node_modules/
.pnp
.pnp.js
.yarn-integrity

# --- Build Output ---
dist/
dist-ssr/
build/
*.tgz
*.tar.gz

# --- Vite Specific ---
.vite/
*.local

# --- Editor Directories & Files ---
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.vscode-test

# IntelliJ / JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*~

# --- OS Generated Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Environment Variables ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.development
.env.test
.env.production
!.env.example

# --- Testing & Coverage ---
coverage/
.nyc_output/
*.lcov
cypress/videos/
cypress/screenshots/
playwright-report/
test-results/

# --- Temporary Files ---
*.tmp
*.temp
.cache/
*.cache
.temp/
tmp/
temp/

# --- Package Manager Lock Files (optional - uncomment if needed) ---
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# --- TypeScript ---
*.tsbuildinfo

# --- ESLint & Prettier ---
.eslintcache
.prettiercache

# --- Storybook ---
storybook-static/

# --- Misc ---
*.local
.history/
nul
